// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User email
//   - displayName: string (optional) - User display name
//   - role: string (required, enum: ['customer', 'staff', 'admin']) - User role
//   - createdAt: timestamp (required) - Creation time
//
// Collection: menu
// Document ID: {itemId}
// Fields:
//   - name: string (required) - Item name
//   - description: string (required) - Item description
//   - price: number (required, positive) - Item price
//   - category: string (required) - Item category
//   - image: string (optional, URL) - Item image URL
//   - isAvailable: bool (required) - Availability status
//
// Collection: orders
// Document ID: {orderId}
// Fields:
//   - customerId: string (required) - UID of the customer
//   - customerName: string (required) - Name of the customer
//   - items: list (required) - List of order items
//   - totalAmount: number (required, positive) - Total order amount
//   - status: string (required, enum: ['pending', 'preparing', 'ready', 'completed', 'cancelled']) - Order status
//   - createdAt: timestamp (required) - Order creation time
//   - updatedAt: timestamp (required) - Last update time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "luigigaspi01@gmail.com" && request.auth.token.email_verified == true));
    }

    function isStaff() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff' || isAdmin());
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['customer', 'staff', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'isAvailable']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() < 500 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() < 50 &&
             data.isAvailable is bool;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'items', 'totalAmount', 'status', 'createdAt', 'updatedAt']) &&
             data.customerId is string && data.customerId == request.auth.uid &&
             data.customerName is string && data.customerName.size() < 100 &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'preparing', 'ready', 'completed', 'cancelled'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'customer' || isAdmin());
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin())) || 
                    (isAdmin() && request.resource.data.role in ['customer', 'staff', 'admin']);
    }

    match /menu/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isStaff());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAuthenticated() && (
        (isOwner(resource.data.customerId) && request.resource.data.status == 'cancelled' && resource.data.status == 'pending') ||
        (isStaff() && isValidOrder(request.resource.data))
      );
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
