{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["customer", "staff", "admin"], "description": "User role in the system" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "Represents a food or beverage item in the cafe menu.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Item name" },
        "description": { "type": "string", "description": "Item description" },
        "price": { "type": "number", "description": "Item price in PHP" },
        "category": { "type": "string", "description": "Item category (e.g., Coffee, Pastry)" },
        "image": { "type": "string", "format": "uri", "description": "URL to item image" },
        "isAvailable": { "type": "boolean", "description": "Availability status" }
      },
      "required": ["name", "price", "category", "isAvailable"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "UID of the customer" },
        "customerName": { "type": "string", "description": "Name of the customer" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "menuItemId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["customerId", "items", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/menu/{itemId}": {
      "schema": "MenuItem",
      "description": "Cafe menu items."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    }
  }
}
